---
import { defaultLocale, getBasePath, getLocalizedPath, locales } from "../i18n/config";
import { messages } from "../i18n/messages";

const fallbackUrl = getLocalizedPath(defaultLocale);
const basePath = getBasePath();
const fallbackTitle = messages[defaultLocale].metadata.title;
const fallbackDescription = messages[defaultLocale].metadata.description;
const contentSecurityPolicy = [
  "default-src 'self'",
  "base-uri 'self'",
  "object-src 'none'",
  "script-src 'self' 'unsafe-inline'",
  "style-src 'self' 'unsafe-inline'",
  "img-src 'self' data: blob:",
  "connect-src 'self'",
  "frame-src 'none'",
  "form-action 'self'",
].join("; ");
---

<!doctype html>
<html lang={defaultLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {import.meta.env.PROD && <meta http-equiv="Content-Security-Policy" content={contentSecurityPolicy} />}
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta http-equiv="Permissions-Policy" content="camera=(), microphone=(), geolocation=(), payment=(), usb=()" />
    <meta name="robots" content="noindex, follow" />
    <meta name="description" content={fallbackDescription} />
    <meta http-equiv="refresh" content={`0;url=${fallbackUrl}`} />
    <title>{fallbackTitle}</title>
  </head>
  <body>
    <p>
      <a href={fallbackUrl}>Kaş Limoncello</a>
    </p>
    <script
      is:inline
      define:vars={{
        basePath,
        defaultLocale,
        supportedLocales: JSON.stringify(locales),
      }}
    >
      try {
        var supported = JSON.parse(supportedLocales);
        var stored = localStorage.getItem("limoncello-locale");
        var browserLocales = navigator.languages && navigator.languages.length
          ? navigator.languages
          : [navigator.language || ""];
        var browserLocale = browserLocales
          .map(function (item) {
            return String(item).toLowerCase().split("-")[0];
          })
          .find(function (item) {
            return supported.indexOf(item) !== -1;
          });
        var target = supported.indexOf(stored) !== -1 ? stored : browserLocale || defaultLocale;
        window.location.replace(basePath + target + "/");
      } catch (error) {
        window.location.replace(basePath + defaultLocale + "/");
      }
    </script>
  </body>
</html>
