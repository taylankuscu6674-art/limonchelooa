---
import LanguageSwitcher from "./LanguageSwitcher.astro";
import type { Locale } from "../i18n/config";
import type { Messages } from "../i18n/messages";

interface Props {
  locale: Locale;
  t: Messages;
}

const { locale, t } = Astro.props;

const links = [
  { href: "#story", label: t.nav.story },
  { href: "#highlights", label: t.nav.craft },
  { href: "#ingredients", label: t.nav.ingredients },
  { href: "#customize", label: t.nav.customize },
  { href: "#showcase", label: t.nav.shop },
  { href: "#experience", label: t.nav.experience },
  { href: "#order", label: t.nav.order },
  { href: "#footer-contact", label: t.nav.contact },
];
---

<header
  class="site-header sticky top-0 z-50 border-b backdrop-blur-md"
  data-site-header
  data-over-visual="true"
>
  <nav
    class="mx-auto grid max-w-6xl grid-cols-[auto,minmax(0,1fr),auto] items-center gap-2 px-4 py-3 sm:gap-3 md:flex md:justify-between md:gap-4 md:px-6 md:py-4"
    aria-label={t.nav.aria}
  >
    <a
      href="#hero"
      class="group flex shrink-0 items-center gap-2 text-sm font-semibold tracking-tight text-ink transition-colors hover:text-gold-dark md:text-base"
    >
      <span
        class="flex h-8 w-8 items-center justify-center rounded-full bg-white/70 text-lg shadow-sm ring-1 ring-lemon-300/40 transition-transform duration-300 group-hover:scale-105"
        aria-hidden="true">🍋</span>
      <span class="hidden sm:inline">{t.brand.name}</span>
    </a>
    <div class="site-header__menu-wrap min-w-0 overflow-hidden md:overflow-visible">
      <ul
        class="site-header__menu flex min-w-0 snap-x flex-nowrap items-center justify-start gap-1 overflow-x-auto scroll-smooth px-0.5 pb-1 text-xs font-medium text-ink/85 md:max-w-none md:flex-wrap md:justify-center md:gap-2 md:overflow-visible md:px-0 md:pb-0 md:text-sm"
        aria-label={t.nav.aria}
      >
        {
          links.map(({ href, label }) => (
            <li class="shrink-0 snap-start">
              <a
                href={href}
                class="block whitespace-nowrap rounded-full px-2.5 py-1.5 transition-colors hover:bg-lemon-300/50 hover:text-ink md:px-3"
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <LanguageSwitcher locale={locale} t={t} />
  </nav>
</header>

<script is:inline>
  (function () {
    function initHeaderTone() {
      var header = document.querySelector("[data-site-header]");
      var visualSections = [
        document.getElementById("hero"),
        document.getElementById("premium-craft"),
      ].filter(Boolean);

      if (!header || !visualSections.length) return;

      var ticking = false;

      function updateHeaderTone() {
        var probeY = header.offsetHeight + 2;
        var overVisual = window.scrollY <= 4 || visualSections.some(function (section) {
          var rect = section.getBoundingClientRect();
          return rect.top <= probeY && rect.bottom >= probeY;
        });

        header.dataset.overVisual = overVisual ? "true" : "false";
        ticking = false;
      }

      function requestUpdate() {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(updateHeaderTone);
      }

      updateHeaderTone();
      window.addEventListener("scroll", requestUpdate, { passive: true });
      window.addEventListener("resize", requestUpdate, { passive: true });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initHeaderTone, { once: true });
    } else {
      initHeaderTone();
    }
  })();
</script>

<style>
  .site-header {
    position: sticky;
    color: #1c1917;
    border-color: rgba(253, 224, 71, 0.5);
    isolation: isolate;
    transition:
      color 900ms ease,
      border-color 900ms ease,
      box-shadow 900ms ease;
  }

  .site-header::before,
  .site-header::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    transition: opacity 900ms ease;
  }

  .site-header::before {
    background: linear-gradient(
      180deg,
      rgba(254, 249, 195, 0.95),
      rgba(254, 240, 138, 0.9)
    );
    opacity: 1;
  }

  .site-header::after {
    background:
      linear-gradient(180deg, rgba(5, 42, 58, 0.58), rgba(6, 63, 92, 0.34)),
      linear-gradient(90deg, rgba(255, 248, 232, 0.12), rgba(255, 248, 232, 0.03));
    opacity: 0;
  }

  .site-header[data-over-visual="true"] {
    color: rgba(255, 253, 247, 0.92);
    border-color: rgba(255, 248, 232, 0.18);
    box-shadow: 0 1rem 2.5rem rgba(5, 42, 58, 0.18);
  }

  .site-header[data-over-visual="true"]::before {
    opacity: 0;
  }

  .site-header[data-over-visual="true"]::after {
    opacity: 1;
  }

  .site-header a,
  .site-header ul {
    color: inherit;
    transition:
      color 900ms ease,
      background-color 300ms ease,
      border-color 900ms ease;
  }

  .site-header__menu {
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .site-header__menu::-webkit-scrollbar {
    display: none;
  }

  .site-header[data-over-visual="true"] a:hover {
    color: #fff8e8;
  }

  .site-header[data-over-visual="true"] nav > a > span:first-child {
    background: rgba(255, 248, 232, 0.2);
    color: #fff8e8;
    box-shadow: 0 0 0 1px rgba(255, 248, 232, 0.2);
  }

  .site-header[data-over-visual="true"] li a:hover {
    background: rgba(255, 248, 232, 0.14);
  }
</style>
