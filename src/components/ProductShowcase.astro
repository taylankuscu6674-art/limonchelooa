---
import { Image } from "astro:assets";
import productImage from "../assets/product/limoncello.jpeg";
import type { Messages } from "../i18n/messages";

interface Props {
  t: Messages;
}

const { t } = Astro.props;
const sizes = ["250ml", "500ml", "700ml"];
---

<section
  id="showcase"
  class="scroll-mt-24 bg-white px-4 py-20 md:px-6 md:py-24"
  aria-labelledby="showcase-heading"
>
  <div class="mx-auto max-w-6xl">
    <h2
      id="showcase-heading"
      class="text-center font-display text-2xl font-semibold tracking-tight text-ink md:text-3xl"
    >
      {t.showcase.title}
    </h2>
    <p class="mx-auto mt-3 max-w-lg text-center text-sm text-stone-soft">
      {t.showcase.lead}
    </p>

    <article
      class="mx-auto mt-12 max-w-md overflow-hidden rounded-3xl border border-gold-light/30 bg-cream shadow-card transition-shadow duration-300 hover:shadow-lg"
    >
      <div class="aspect-[4/5] overflow-hidden bg-lemon-100/50">
        <Image
          src={productImage}
          alt={t.showcase.productAlt}
          width={800}
          height={1000}
          class="h-full w-full object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="p-6 md:p-8">
        <h3 class="text-lg font-semibold text-ink">{t.showcase.productName}</h3>
        <p class="mt-2 text-sm font-light leading-relaxed text-stone-soft">
          {t.showcase.productDescription}
        </p>
        <form
          id="product-quick-order-form"
          class="relative mt-6"
          action="#"
          method="post"
          accept-charset="UTF-8"
          data-security-key="kas-limoncello-quick-order-form"
          data-security-min-delay-ms="1200"
          data-security-cooldown-ms="12000"
          data-security-too-fast={t.order.security.tooFast}
          data-security-cooldown={t.order.security.cooldown}
          data-message-title={t.showcase.quickOrderMessage.title}
          data-message-product-label={t.showcase.quickOrderMessage.product}
          data-message-size-label={t.showcase.quickOrderMessage.size}
          data-message-customization={t.showcase.quickOrderMessage.customization}
          data-product-name={t.showcase.productName}
        >
          <div
            class="pointer-events-none absolute -left-[100vw] top-auto h-px w-px overflow-hidden opacity-0"
            aria-hidden="true"
          >
            <label for="quick-order-company">{t.order.security.honeypot}</label>
            <input
              id="quick-order-company"
              name="company"
              type="text"
              tabindex="-1"
              autocomplete="off"
              data-security-honeypot
            />
          </div>
          <p class="sr-only" aria-live="polite" data-security-status></p>
          <fieldset>
            <legend class="sr-only">{t.showcase.sizeLegend}</legend>
            <div class="flex flex-wrap gap-2">
              {
                sizes.map((size) => (
                  <label class="cursor-pointer">
                    <input
                      class="peer sr-only"
                      type="radio"
                      name="quick-size"
                      value={size}
                      checked={size === "500ml"}
                    />
                    <span class="flex h-9 min-w-16 items-center justify-center rounded-lg border border-gold-light/40 bg-white px-3 text-xs font-medium text-ink transition-colors peer-checked:border-ink peer-checked:bg-ink peer-checked:text-cream peer-focus-visible:outline peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-gold">
                      {size}
                    </span>
                  </label>
                ))
              }
            </div>
          </fieldset>
          <button
            type="submit"
            class="mt-8 flex w-full items-center justify-center rounded-lg bg-ink py-3.5 text-sm font-semibold text-cream transition-colors duration-300 hover:bg-gold-dark"
          >
            {t.showcase.button}
          </button>
        </form>
      </div>
    </article>
  </div>
</section>

<script>
  import {
    guardSecureSubmission,
    openSecureExternalUrl,
    prepareSecureForm,
    showGuardMessage,
  } from "../scripts/order-security";

  const form = document.getElementById("product-quick-order-form") as HTMLFormElement | null;
  if (form) {
    prepareSecureForm(form);

    form.addEventListener("submit", function (e) {
      e.preventDefault();
      const guard = guardSecureSubmission(form);
      if (!guard.ok) {
        if (guard.message) {
          showGuardMessage(form, guard.message);
        }
        return;
      }

      var selected = form.querySelector<HTMLInputElement>('input[name="quick-size"]:checked');
      var size = selected && selected.value ? selected.value : "500ml";
      var messageLines = [
        form.dataset.messageTitle || "New direct limoncello order request",
        (form.dataset.messageProductLabel || "Product") + ": " + (form.dataset.productName || "Kas Signature Limoncello"),
        (form.dataset.messageSizeLabel || "Bottle size") + ": " + size,
        form.dataset.messageCustomization || "Customization: None",
      ];

      var waNumber = "905313186674";
      var waUrl =
        "https://wa.me/" +
        waNumber +
        "?text=" +
        encodeURIComponent(messageLines.join("\n"));

      openSecureExternalUrl(waUrl);
    });
  }
</script>
