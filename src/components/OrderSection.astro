---
import type { Messages } from "../i18n/messages";

interface Props {
  t: Messages;
}

const { t } = Astro.props;
---

<section
  id="order"
  class="scroll-mt-24 bg-cream px-4 py-20 md:px-6 md:py-28"
  aria-labelledby="order-heading"
>
  <div class="mx-auto max-w-xl">
    <h2
      id="order-heading"
      class="text-center font-display text-2xl font-semibold tracking-tight text-ink md:text-3xl"
    >
      {t.order.title}
    </h2>
    <p class="mx-auto mt-3 max-w-md text-center text-sm text-stone-soft">
      {t.order.lead}
    </p>

    <form
      id="limoncello-order-form"
      class="relative mt-10 space-y-5 rounded-3xl border border-gold-light/30 bg-white p-6 shadow-soft md:p-8"
      method="post"
      action="#"
      accept-charset="UTF-8"
      data-alert={t.order.alert}
      data-security-key="kas-limoncello-order-form"
      data-security-min-delay-ms="1800"
      data-security-cooldown-ms="18000"
      data-security-too-fast={t.order.security.tooFast}
      data-security-cooldown={t.order.security.cooldown}
      data-message-title={t.order.whatsapp.title}
      data-label-name={t.order.whatsapp.name}
      data-label-email={t.order.whatsapp.email}
      data-label-phone={t.order.whatsapp.phone}
      data-label-address={t.order.whatsapp.address}
      data-label-size={t.order.whatsapp.size}
      data-label-customization={t.order.whatsapp.customization}
    >
      <div
        class="pointer-events-none absolute -left-[100vw] top-auto h-px w-px overflow-hidden opacity-0"
        aria-hidden="true"
      >
        <label for="order-company">{t.order.security.honeypot}</label>
        <input
          id="order-company"
          name="company"
          type="text"
          tabindex="-1"
          autocomplete="off"
          data-security-honeypot
        />
      </div>
      <p class="sr-only" aria-live="polite" data-security-status></p>
      <div>
        <label for="order-name" class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-stone-soft"
          >{t.order.labels.name}</label
        >
        <input
          id="order-name"
          name="name"
          type="text"
          required
          autocomplete="name"
          maxlength="80"
          class="w-full rounded-xl border border-gold-light/40 bg-cream/30 px-4 py-3 text-sm text-ink transition-colors placeholder:text-stone-soft/60 focus:border-gold focus:bg-white focus:outline-none"
          placeholder={t.order.placeholders.name}
        />
      </div>
      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="order-email" class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-stone-soft"
            >{t.order.labels.email}</label
          >
          <input
            id="order-email"
            name="email"
            type="email"
            autocomplete="email"
            maxlength="120"
            class="w-full rounded-xl border border-gold-light/40 bg-cream/30 px-4 py-3 text-sm text-ink transition-colors placeholder:text-stone-soft/60 focus:border-gold focus:bg-white focus:outline-none"
            placeholder={t.order.placeholders.email}
          />
        </div>
        <div>
          <label for="order-phone" class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-stone-soft"
            >{t.order.labels.phone}</label
          >
          <input
            id="order-phone"
            name="phone"
            type="tel"
            autocomplete="tel"
            inputmode="tel"
            maxlength="32"
            class="w-full rounded-xl border border-gold-light/40 bg-cream/30 px-4 py-3 text-sm text-ink transition-colors placeholder:text-stone-soft/60 focus:border-gold focus:bg-white focus:outline-none"
            placeholder={t.order.placeholders.phone}
          />
        </div>
      </div>
      <p class="text-xs text-stone-soft">
        {t.order.contactRequirement}
      </p>
      <div>
        <label for="order-address" class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-stone-soft"
          >{t.order.labels.address}</label
        >
        <textarea
          id="order-address"
          name="address"
          required
          rows={3}
          maxlength="420"
          class="w-full resize-y rounded-xl border border-gold-light/40 bg-cream/30 px-4 py-3 text-sm text-ink transition-colors placeholder:text-stone-soft/60 focus:border-gold focus:bg-white focus:outline-none"
          placeholder={t.order.placeholders.address}
        ></textarea>
      </div>
      <div>
        <label for="order-size" class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-stone-soft"
          >{t.order.labels.size}</label
        >
        <select
          id="order-size"
          name="size"
          required
          class="w-full rounded-xl border border-gold-light/40 bg-cream/30 px-4 py-3 text-sm text-ink transition-colors focus:border-gold focus:bg-white focus:outline-none"
        >
          <option value="">{t.order.sizePlaceholder}</option>
          <option value="250ml">250ml</option>
          <option value="500ml">500ml</option>
          <option value="700ml">700ml</option>
        </select>
      </div>
      <div>
        <label
          for="order-notes"
          class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-stone-soft"
          >{t.order.labels.notes}</label
        >
        <textarea
          id="order-notes"
          name="notes"
          rows={3}
          maxlength="300"
          class="w-full resize-y rounded-xl border border-gold-light/40 bg-cream/30 px-4 py-3 text-sm text-ink transition-colors placeholder:text-stone-soft/60 focus:border-gold focus:bg-white focus:outline-none"
          placeholder={t.order.placeholders.notes}
        ></textarea>
      </div>
      <button
        type="submit"
        class="w-full rounded-full bg-ink py-4 text-sm font-semibold text-cream transition-colors duration-300 hover:bg-gold-dark hover:shadow-card"
      >
        {t.order.button}
      </button>
    </form>
  </div>
</section>

<script>
  import {
    guardSecureSubmission,
    openSecureExternalUrl,
    prepareSecureForm,
    sanitizeForMessage,
    showGuardMessage,
  } from "../scripts/order-security";

  const form = document.getElementById("limoncello-order-form") as HTMLFormElement | null;
  if (form) {
    prepareSecureForm(form);

    form.addEventListener("submit", function (e) {
      e.preventDefault();
      var email = document.getElementById("order-email") as HTMLInputElement | null;
      var phone = document.getElementById("order-phone") as HTMLInputElement | null;
      var hasEmail = email && sanitizeForMessage(email.value, 120);
      var hasPhone = phone && sanitizeForMessage(phone.value, 32);
      if (!hasEmail && !hasPhone) {
        alert(form.dataset.alert || "Please enter an email or phone number so we can confirm your order.");
        return;
      }

      const guard = guardSecureSubmission(form);
      if (!guard.ok) {
        if (guard.message) {
          showGuardMessage(form, guard.message);
        }
        return;
      }

      var name = document.getElementById("order-name") as HTMLInputElement | null;
      var address = document.getElementById("order-address") as HTMLTextAreaElement | null;
      var size = document.getElementById("order-size") as HTMLSelectElement | null;
      var notes = document.getElementById("order-notes") as HTMLTextAreaElement | null;

      var messageLines = [
        form.dataset.messageTitle || "New limoncello order request",
        (form.dataset.labelName || "Name") + ": " + (name && name.value ? sanitizeForMessage(name.value, 80) : "-"),
        (form.dataset.labelEmail || "Email") + ": " + (email && email.value ? sanitizeForMessage(email.value, 120) : "-"),
        (form.dataset.labelPhone || "Phone") + ": " + (phone && phone.value ? sanitizeForMessage(phone.value, 32) : "-"),
        (form.dataset.labelAddress || "Address") + ": " + (address && address.value ? sanitizeForMessage(address.value, 420) : "-"),
        (form.dataset.labelSize || "Bottle size") + ": " + (size && size.value ? size.value : "-"),
        (form.dataset.labelCustomization || "Customization") + ": " + (notes && notes.value ? sanitizeForMessage(notes.value, 300) : "-"),
      ];

      var waNumber = "905313186674";
      var waUrl =
        "https://wa.me/" +
        waNumber +
        "?text=" +
        encodeURIComponent(messageLines.join("\n"));

      openSecureExternalUrl(waUrl);

      form.reset();
    });
  }
</script>
