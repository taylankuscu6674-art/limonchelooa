<div
  class="scene-orchestrator"
  data-scene-orchestrator
  aria-hidden="true"
>
  <div class="scene-orchestrator__layer is-active" data-scene-layer="a"></div>
  <div class="scene-orchestrator__layer" data-scene-layer="b"></div>
  <div class="scene-orchestrator__light" data-scene-light></div>
  <div class="scene-orchestrator__grain"></div>
</div>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const sceneConfig = {
    scrub: 0.42,
    handoffDistance: 0.36,
    entranceDistance: 0.74,
    depth: 0.72,
    blur: 4,
    overlayFade: 0.9,
  };

  const sceneProfiles = {
    hero: {
      top: "#052a3a",
      bottom: "#063f5c",
      glow: "rgba(246, 214, 66, 0.28)",
      wash: "rgba(255, 248, 232, 0.18)",
      position: "70% 18%",
      intensity: 0.32,
      light: 0.32,
      entrance: "hero",
    },
    "premium-craft": {
      top: "#052a3a",
      bottom: "#fff3c9",
      glow: "rgba(246, 214, 66, 0.26)",
      wash: "rgba(6, 63, 92, 0.24)",
      position: "72% 18%",
      intensity: 0.34,
      light: 0.38,
      entrance: "managed",
    },
    story: {
      top: "#fef9c3",
      bottom: "#fefce8",
      glow: "rgba(200, 164, 93, 0.24)",
      wash: "rgba(255, 255, 255, 0.24)",
      position: "50% 20%",
      intensity: 0.2,
      light: 0.24,
    },
    highlights: {
      top: "#f6d642",
      bottom: "#fef9c3",
      glow: "rgba(255, 248, 232, 0.32)",
      wash: "rgba(246, 214, 66, 0.2)",
      position: "18% 18%",
      intensity: 0.24,
      light: 0.28,
    },
    ingredients: {
      top: "#fff8e8",
      bottom: "#fefce8",
      glow: "rgba(246, 214, 66, 0.24)",
      wash: "rgba(6, 63, 92, 0.08)",
      position: "80% 30%",
      intensity: 0.2,
      light: 0.22,
    },
    customize: {
      top: "#fefcf8",
      bottom: "#fff8e8",
      glow: "rgba(200, 164, 93, 0.22)",
      wash: "rgba(255, 248, 232, 0.28)",
      position: "50% 12%",
      intensity: 0.18,
      light: 0.2,
    },
    showcase: {
      top: "#fffdf7",
      bottom: "#fff3c9",
      glow: "rgba(246, 214, 66, 0.28)",
      wash: "rgba(6, 63, 92, 0.1)",
      position: "65% 22%",
      intensity: 0.24,
      light: 0.32,
    },
    experience: {
      top: "#fff8e8",
      bottom: "#fefcf8",
      glow: "rgba(255, 248, 232, 0.28)",
      wash: "rgba(200, 164, 93, 0.14)",
      position: "40% 16%",
      intensity: 0.16,
      light: 0.18,
    },
    testimonials: {
      top: "#fffdf7",
      bottom: "#fff8e8",
      glow: "rgba(200, 164, 93, 0.18)",
      wash: "rgba(6, 63, 92, 0.08)",
      position: "76% 20%",
      intensity: 0.16,
      light: 0.18,
    },
    urgency: {
      top: "#052a3a",
      bottom: "#1f1a14",
      glow: "rgba(246, 214, 66, 0.22)",
      wash: "rgba(255, 248, 232, 0.08)",
      position: "62% 12%",
      intensity: 0.34,
      light: 0.28,
    },
    order: {
      top: "#fefcf8",
      bottom: "#fff3c9",
      glow: "rgba(246, 214, 66, 0.22)",
      wash: "rgba(255, 248, 232, 0.32)",
      position: "50% 18%",
      intensity: 0.18,
      light: 0.2,
    },
  };

  const sceneOrder = [
    "hero",
    "premium-craft",
    "story",
    "highlights",
    "ingredients",
    "customize",
    "showcase",
    "experience",
    "testimonials",
    "urgency",
    "order",
  ];

  const overlay = document.querySelector("[data-scene-orchestrator]");
  const layers = overlay
    ? Array.from(overlay.querySelectorAll("[data-scene-layer]"))
    : [];
  const light = overlay?.querySelector("[data-scene-light]");
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  const entranceTravel = 26 + sceneConfig.depth * 12;
  const handoffTravel = -12 - sceneConfig.depth * 10;
  const lightTravel = 14 + sceneConfig.depth * 8;

  if (overlay && layers.length && !reducedMotion.matches) {
    const sections = sceneOrder
      .map((id) => document.getElementById(id))
      .filter(Boolean);

    let activeLayer = 0;
    let activeScene = "";

    function sceneBackground(profile) {
      return [
        `radial-gradient(circle at ${profile.position}, ${profile.glow}, rgba(246, 214, 66, 0) 38%)`,
        `linear-gradient(180deg, ${profile.top} 0%, ${profile.wash} 42%, ${profile.bottom} 100%)`,
      ].join(", ");
    }

    function applyScene(section) {
      const profile = sceneProfiles[section.id] || sceneProfiles.story;
      section.classList.add("cinematic-scene");
      section.dataset.sceneProfile = section.id;
      section.style.setProperty("--scene-top", profile.top);
      section.style.setProperty("--scene-bottom", profile.bottom);
      section.style.setProperty("--scene-glow", profile.glow);
      section.style.setProperty("--scene-wash", profile.wash);
      section.style.setProperty("--scene-light", String(profile.light));
      section.style.setProperty("--scene-depth", String(sceneConfig.depth));
      section.style.setProperty("--scene-overlay", String(profile.intensity));
    }

    function activateScene(section) {
      if (!section || activeScene === section.id) return;
      activeScene = section.id;

      const profile = sceneProfiles[section.id] || sceneProfiles.story;
      const incomingLayer = layers[activeLayer ? 0 : 1];
      const outgoingLayer = layers[activeLayer];

      incomingLayer.style.background = sceneBackground(profile);
      incomingLayer.style.opacity = String(profile.intensity);

      gsap.to(incomingLayer, {
        opacity: profile.intensity,
        duration: sceneConfig.overlayFade,
        ease: "power2.out",
      });
      gsap.to(outgoingLayer, {
        opacity: 0,
        duration: sceneConfig.overlayFade,
        ease: "power2.out",
      });
      gsap.to(light, {
        opacity: profile.light,
        xPercent: section.id === "urgency" ? 16 : -8,
        duration: 1.15,
        ease: "power2.out",
      });

      activeLayer = activeLayer ? 0 : 1;
    }

    function sceneEntranceTargets(section) {
      if (section.id === "premium-craft") return [];

      const candidates = gsap.utils.toArray(
        section.querySelectorAll(
        [
          ":scope h1",
          ":scope h2",
          ":scope h3",
          ":scope p",
          ":scope article",
          ":scope figure",
          ":scope form",
          ":scope li",
        ].join(", "),
        ),
      );

      return candidates
        .filter((item, index) => {
          if (item.closest("[data-scene-orchestrator]")) return false;
          if (item.closest("script, style")) return false;
          if (candidates.indexOf(item) !== index) return false;

          const animatedParent = candidates.find((parent) => {
            if (parent === item) return false;
            return parent.matches("article, form, figure, li") && parent.contains(item);
          });

          return !animatedParent;
        })
        .slice(0, 14);
    }

    function sceneHandoffTargets(section) {
      if (section.id === "premium-craft") return [];

      return Array.from(section.children)
        .filter((item) => {
          if (item.matches("script, style")) return false;
          if (item.classList.contains("absolute")) return false;
          if (item.closest("[data-scene-orchestrator]")) return false;
          return true;
        })
        .slice(0, 3);
    }

    sections.forEach((section, index) => {
      applyScene(section);

      ScrollTrigger.create({
        trigger: section,
        start: "top 58%",
        end: "bottom 42%",
        onEnter: () => activateScene(section),
        onEnterBack: () => activateScene(section),
      });

      gsap.fromTo(
        section,
        {
          "--scene-progress": 0,
          "--scene-light-shift": `${-lightTravel}%`,
        },
        {
          "--scene-progress": 1,
          "--scene-light-shift": `${lightTravel}%`,
          ease: "none",
          scrollTrigger: {
            trigger: section,
            start: "top 92%",
            end: "top 12%",
            scrub: sceneConfig.scrub,
            fastScrollEnd: true,
            invalidateOnRefresh: true,
          },
        },
      );

      const content = sceneEntranceTargets(section);
      if (content.length) {
        gsap.from(content, {
          autoAlpha: 0,
          y: entranceTravel,
          scale: 0.985,
          filter: `blur(${sceneConfig.blur}px)`,
          clearProps: "filter",
          duration: 0.86,
          stagger: 0.055,
          ease: "power3.out",
          scrollTrigger: {
            trigger: section,
            start: index === 0 ? "top 72%" : "top 76%",
            once: true,
          },
        });

        const handoffTargets = sceneHandoffTargets(section);

        gsap.to(handoffTargets, {
          y: handoffTravel,
          autoAlpha: 0.88,
          scale: 0.995,
          ease: "none",
          scrollTrigger: {
            trigger: section,
            start: "bottom 82%",
            end: "bottom 30%",
            scrub: sceneConfig.handoffDistance,
            fastScrollEnd: true,
          },
        });
      }
    });

    activateScene(sections[0]);
  }
</script>

<style is:global>
  .scene-orchestrator {
    position: fixed;
    inset: 0;
    z-index: 35;
    pointer-events: none;
    overflow: hidden;
  }

  .scene-orchestrator__layer,
  .scene-orchestrator__light,
  .scene-orchestrator__grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .scene-orchestrator__layer {
    opacity: 0;
    transition: opacity 900ms ease;
    will-change: opacity;
  }

  .scene-orchestrator__light {
    opacity: 0.22;
    transform: translate3d(-8%, 0, 0);
    background:
      linear-gradient(108deg, transparent 8%, rgba(255, 248, 232, 0.2) 42%, transparent 62%),
      radial-gradient(circle at 72% 18%, rgba(246, 214, 66, 0.24), transparent 30%);
    will-change: transform, opacity;
  }

  .scene-orchestrator__grain {
    opacity: 0.045;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.28) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.18) 1px, transparent 1px);
    background-size: 54px 54px;
  }

  .cinematic-scene {
    --scene-progress: 0;
    --scene-light-shift: -18%;
    --scene-overlay: 0.18;
    --scene-light: 0.2;
    position: relative;
    isolation: isolate;
    overflow: clip;
    contain: paint style;
  }

  .cinematic-scene::before,
  .cinematic-scene::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .cinematic-scene::before {
    opacity: calc(var(--scene-overlay) * 0.5);
    transform: scale(calc(1 + (var(--scene-progress) * var(--scene-depth) * 0.012)));
    background:
      radial-gradient(circle at 75% 18%, var(--scene-glow), transparent 34%),
      linear-gradient(180deg, var(--scene-top), transparent 46%, var(--scene-bottom));
    will-change: transform, opacity;
  }

  .cinematic-scene::after {
    opacity: calc(var(--scene-progress) * var(--scene-light));
    transform: translate3d(var(--scene-light-shift), 0, 0);
    background: linear-gradient(105deg, transparent 16%, rgba(255, 248, 232, 0.22) 48%, transparent 66%);
    will-change: transform, opacity;
  }

  .cinematic-scene > * {
    position: relative;
    z-index: 2;
  }

  .cinematic-scene img,
  .cinematic-scene figure,
  .cinematic-scene article,
  .cinematic-scene form,
  .cinematic-scene h1,
  .cinematic-scene h2,
  .cinematic-scene h3,
  .cinematic-scene p {
    backface-visibility: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    .scene-orchestrator {
      display: none;
    }

    .cinematic-scene::before,
    .cinematic-scene::after {
      display: none;
    }
  }
</style>
