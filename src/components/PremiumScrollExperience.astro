---
import { Image } from "astro:assets";
import coastImage from "../assets/background2/hero.png";
import productImage from "../assets/product/limoncello.jpeg";

const storyBlocks = [
  {
    eyebrow: "01 / Lemons",
    title: "Kaş citrus, selected for aroma",
    text: "Bright peels are chosen for oil, color, and fragrance before a slow infusion begins.",
  },
  {
    eyebrow: "02 / Craft",
    title: "Small batches, finished by hand",
    text: "Each bottle is balanced in measured runs, giving the liqueur a clean body and a precise finish.",
  },
  {
    eyebrow: "03 / Serve",
    title: "Ice-cold, coastal, refined",
    text: "Serve after dinner or over a single cube when the evening turns warm and gold.",
  },
];
---

<section
  id="premium-craft"
  class="premium-scroll"
  data-premium-scroll
  data-motion-managed
  aria-labelledby="premium-craft-heading"
>
  <div class="premium-scroll__pin" data-premium-pin>
    <div class="premium-scroll__scene" aria-hidden="true">
      <Image
        src={coastImage}
        alt=""
        width={1024}
        height={728}
        sizes="100vw"
        class="premium-scroll__coast"
        data-coast
      />
      <div class="premium-scroll__light" data-light></div>
      <div class="premium-scroll__shade"></div>
      <div class="premium-scroll__grain"></div>
    </div>

    <div class="premium-scroll__content">
      <div class="premium-scroll__copy">
        <p class="premium-scroll__eyebrow" data-intro data-intro-soft>
          Kaş / Antalya / Handmade Limoncello
        </p>
        <h2 id="premium-craft-heading" data-intro>
          A coastal ritual, bottled in sunlight.
        </h2>
        <p class="premium-scroll__lead" data-intro data-intro-soft>
          Mediterranean lemons, cool glass, and slow craft come together in a
          limoncello made for long summer tables.
        </p>
        <ul class="premium-scroll__highlights" aria-label="Product highlights">
          <li data-highlight>Handmade</li>
          <li data-highlight>Premium ingredients</li>
          <li data-highlight>Kaş citrus</li>
        </ul>
      </div>

      <figure class="premium-scroll__product" data-product>
        <Image
          src={productImage}
          alt="Limoncello bottle on a coastal terrace in Kaş"
          width={900}
          height={1125}
          sizes="(min-width: 900px) 34rem, 88vw"
          class="premium-scroll__product-image"
        />
        <figcaption>Signature limoncello, hand-finished in Antalya.</figcaption>
      </figure>
    </div>
  </div>

  <div class="premium-story">
    <div class="premium-story__intro">
      <p data-story-kicker>Craft Notes</p>
      <h3 data-story-heading>Designed to unfold slowly.</h3>
      <p data-story-text>
        The section continues with a measured story rhythm: no loud tricks, just
        warm light, deep sea tones, and refined motion that reveals the bottle’s
        character piece by piece.
      </p>
    </div>

    <div class="premium-story__grid" data-story-grid>
      {
        storyBlocks.map((block) => (
          <article class="premium-story__block" data-story-block>
            <p>{block.eyebrow}</p>
            <h4>{block.title}</h4>
            <span>{block.text}</span>
          </article>
        ))
      }
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const root = document.querySelector("[data-premium-scroll]");
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  if (root && !reducedMotion.matches) {
    ScrollTrigger.config({
      ignoreMobileResize: true,
    });

    const motion = {
      scrub: 0.34,
      revealY: 28,
      ease: "power3.out",
    };

    const q = gsap.utils.selector(root);
    const storyIntro = q(".premium-story__intro")[0];
    const storyGrid = q("[data-story-grid]")[0];
    const introItems = q("[data-intro]");
    const highlights = q("[data-highlight]");
    const product = q("[data-product]");
    const coast = q("[data-coast]");
    const light = q("[data-light]");

    gsap.set([...coast, ...product, ...light], {
      force3D: true,
      transformOrigin: "center center",
    });

    gsap.set(coast, {
      scale: 1.045,
      yPercent: 0,
    });

    gsap.set(product, {
      autoAlpha: 0,
      y: 34,
      scale: 0.985,
    });

    gsap.set([...introItems, ...highlights], {
      autoAlpha: 0,
      y: motion.revealY,
    });

    gsap
      .timeline({
        scrollTrigger: {
          trigger: root,
          start: "top 78%",
          once: true,
        },
        defaults: {
          ease: motion.ease,
        },
      })
      .to(product, { autoAlpha: 1, y: 0, scale: 1, duration: 0.9 }, 0)
      .to(introItems, { autoAlpha: 1, y: 0, duration: 0.82, stagger: 0.075 }, 0.08)
      .to(highlights, { autoAlpha: 1, y: 0, duration: 0.72, stagger: 0.06 }, 0.3);

    gsap.to(coast, {
      scale: 1.015,
      yPercent: -2.4,
      ease: "none",
      scrollTrigger: {
        trigger: root,
        start: "top bottom",
        end: "bottom top",
        scrub: motion.scrub,
        invalidateOnRefresh: true,
        fastScrollEnd: true,
      },
    });

    gsap.to(product, {
      yPercent: -3,
      ease: "none",
      scrollTrigger: {
        trigger: root,
        start: "top 72%",
        end: "bottom top",
        scrub: motion.scrub,
        invalidateOnRefresh: true,
        fastScrollEnd: true,
      },
    });

    gsap.to(light, {
      xPercent: 12,
      opacity: 0.56,
      ease: "none",
      scrollTrigger: {
        trigger: root,
        start: "top bottom",
        end: "bottom top",
        scrub: motion.scrub,
        invalidateOnRefresh: true,
      },
    });

    gsap.from(q("[data-story-kicker], [data-story-heading], [data-story-text]"), {
      scrollTrigger: {
        trigger: storyIntro,
        start: "top 78%",
        once: true,
      },
      autoAlpha: 0,
      y: 24,
      duration: 0.82,
      stagger: 0.09,
      ease: motion.ease,
    });

    gsap.from(q("[data-story-block]"), {
      scrollTrigger: {
        trigger: storyGrid,
        start: "top 80%",
        once: true,
      },
      autoAlpha: 0,
      y: 28,
      duration: 0.78,
      stagger: 0.1,
      ease: motion.ease,
    });
  }
</script>

<style>
  .premium-scroll {
    --premium-sea: #063f5c;
    --premium-deep-sea: #052a3a;
    --premium-lemon: #f6d642;
    --premium-gold: #c8a45d;
    --premium-cream: #fff8e8;
    --premium-white: #fffdf7;
    --premium-ink: #1f1a14;
    position: relative;
    background:
      linear-gradient(180deg, var(--premium-deep-sea) 0%, #fff3c9 46%, #fefcf8 100%);
    color: var(--premium-ink);
    isolation: isolate;
    overflow: clip;
    margin-top: -1px;
  }

  .premium-scroll::before,
  .premium-scroll::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    z-index: 20;
    height: 8rem;
    pointer-events: none;
  }

  .premium-scroll::before {
    top: 0;
    background: linear-gradient(180deg, #052a3a 0%, rgba(5, 42, 58, 0.72) 30%, rgba(5, 42, 58, 0) 100%);
  }

  .premium-scroll::after {
    bottom: 0;
    height: 12rem;
    background:
      linear-gradient(
        180deg,
        rgba(253, 252, 248, 0) 0%,
        rgba(255, 248, 232, 0.38) 30%,
        rgba(245, 232, 170, 0.82) 66%,
        #fef9c3 100%
      );
  }

  .premium-scroll__pin {
    position: relative;
    min-height: 100svh;
    overflow: hidden;
    display: grid;
    align-items: center;
    background: var(--premium-deep-sea);
    contain: paint style;
    transform: translateZ(0);
  }

  .premium-scroll__scene,
  .premium-scroll__scene::after {
    position: absolute;
    inset: 0;
  }

  .premium-scroll__scene {
    left: 50%;
    width: 120vw;
    max-width: none;
    transform: translate3d(-50%, 0, 0);
    overflow: hidden;
  }

  .premium-scroll__scene::after {
    content: "";
    z-index: 5;
    pointer-events: none;
    background:
      linear-gradient(90deg, rgba(5, 42, 58, 0.82) 0%, rgba(5, 42, 58, 0.48) 34%, rgba(5, 42, 58, 0.1) 100%),
      linear-gradient(180deg, rgba(255, 248, 232, 0.22) 0%, rgba(255, 248, 232, 0) 38%, rgba(5, 42, 58, 0.52) 100%);
  }

  .premium-scroll__coast {
    position: absolute;
    inset: -5% 0;
    z-index: 1;
    width: 100%;
    max-width: none;
    height: 110%;
    object-fit: cover;
    transform-origin: center center;
  }

  .premium-scroll__coast,
  .premium-scroll__light,
  .premium-scroll__product,
  .premium-scroll [data-intro],
  .premium-scroll [data-highlight] {
    backface-visibility: hidden;
    transform: translate3d(0, 0, 0);
    will-change: transform, opacity;
  }

  .premium-scroll__light,
  .premium-scroll__shade,
  .premium-scroll__grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .premium-scroll__light {
    z-index: 2;
    opacity: 0.42;
    background:
      radial-gradient(circle at 78% 18%, rgba(246, 214, 66, 0.3), transparent 30%),
      linear-gradient(112deg, transparent 12%, rgba(255, 248, 232, 0.16) 46%, transparent 68%);
  }

  .premium-scroll__shade {
    z-index: 4;
    background:
      radial-gradient(circle at 50% 100%, rgba(255, 248, 232, 0.16), transparent 34%),
      linear-gradient(180deg, rgba(5, 42, 58, 0.12) 0%, rgba(5, 42, 58, 0.08) 44%, rgba(5, 42, 58, 0.42) 100%);
  }

  .premium-scroll__grain {
    z-index: 6;
    opacity: 0.032;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.2) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.16) 1px, transparent 1px);
    background-size: 58px 58px;
  }

  .premium-scroll__content {
    position: relative;
    z-index: 10;
    width: min(72rem, calc(100% - 2rem));
    margin: 0 auto;
    display: grid;
    grid-template-columns: 0.96fr 1.04fr;
    gap: 4rem;
    align-items: center;
    padding: clamp(7rem, 10vh, 8rem) 0 6rem;
  }

  .premium-scroll__copy {
    max-width: 36rem;
    color: var(--premium-white);
  }

  .premium-scroll__eyebrow {
    margin: 0 0 1rem;
    font-size: 0.78rem;
    line-height: 1.5;
    text-transform: uppercase;
    letter-spacing: 0;
    color: rgba(255, 248, 232, 0.74);
  }

  .premium-scroll h2 {
    margin: 0;
    max-width: 12ch;
    font-size: 4.25rem;
    line-height: 0.95;
    font-weight: 600;
    letter-spacing: 0;
    color: var(--premium-white);
    text-wrap: balance;
  }

  .premium-scroll__lead {
    margin: 1.6rem 0 0;
    max-width: 33rem;
    font-size: 1.08rem;
    line-height: 1.9;
    font-weight: 300;
    color: rgba(255, 248, 232, 0.82);
  }

  .premium-scroll__highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin: 2rem 0 0;
    padding: 0;
    list-style: none;
  }

  .premium-scroll__highlights li {
    min-height: 2.35rem;
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(255, 248, 232, 0.26);
    border-radius: 8px;
    padding: 0.45rem 0.78rem;
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 248, 232, 0.88);
    font-size: 0.78rem;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18);
  }

  .premium-scroll__product {
    position: relative;
    justify-self: end;
    width: min(100%, 34rem);
    margin: 0;
  }

  .premium-scroll__product::before,
  .premium-scroll__product::after {
    content: "";
    position: absolute;
    pointer-events: none;
  }

  .premium-scroll__product::before {
    inset: -1px;
    z-index: 2;
    border-radius: 8px;
    border: 1px solid rgba(255, 248, 232, 0.34);
    box-shadow:
      0 2rem 5rem rgba(5, 42, 58, 0.34),
      0 0 0 1px rgba(200, 164, 93, 0.14);
  }

  .premium-scroll__product::after {
    left: 10%;
    right: 10%;
    bottom: -1.4rem;
    height: 2.2rem;
    border-radius: 50%;
    background: rgba(255, 223, 112, 0.24);
    opacity: 0.7;
  }

  .premium-scroll__product-image {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    height: auto;
    border-radius: 8px;
    object-fit: cover;
    object-position: 66% 50%;
    box-shadow: 0 1.5rem 4.5rem rgba(2, 22, 30, 0.36);
  }

  .premium-scroll__product figcaption {
    margin-top: 1rem;
    color: rgba(255, 248, 232, 0.66);
    font-size: 0.8rem;
    line-height: 1.6;
  }

  .premium-story {
    width: min(72rem, calc(100% - 2rem));
    margin: 0 auto;
    padding: 8rem 0 9rem;
  }

  .premium-story__intro {
    max-width: 44rem;
  }

  .premium-story__intro p:first-child,
  .premium-story__block p {
    margin: 0 0 0.85rem;
    color: var(--premium-gold);
    font-size: 0.78rem;
    line-height: 1.5;
    text-transform: uppercase;
    letter-spacing: 0;
  }

  .premium-story__intro h3 {
    margin: 0;
    color: var(--premium-ink);
    font-size: 3.2rem;
    line-height: 1.05;
    font-weight: 600;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .premium-story__intro p:last-child {
    margin: 1.35rem 0 0;
    max-width: 40rem;
    color: #5c564e;
    font-size: 1.02rem;
    line-height: 1.9;
    font-weight: 300;
  }

  .premium-story__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 4rem;
  }

  .premium-story__block {
    min-height: 18rem;
    border-radius: 8px;
    border: 1px solid rgba(200, 164, 93, 0.22);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(255, 248, 232, 0.62)),
      linear-gradient(135deg, rgba(246, 214, 66, 0.08), rgba(6, 63, 92, 0.06));
    padding: 1.4rem;
    box-shadow: 0 1.25rem 3rem rgba(31, 26, 20, 0.07);
  }

  .premium-story__block h4 {
    margin: 0;
    color: var(--premium-ink);
    font-size: 1.35rem;
    line-height: 1.25;
    font-weight: 600;
    letter-spacing: 0;
  }

  .premium-story__block span {
    display: block;
    margin-top: 1.1rem;
    color: #665f55;
    font-size: 0.96rem;
    line-height: 1.8;
    font-weight: 300;
  }

  @media (max-width: 900px) {
    .premium-scroll__content {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 6rem 0 5rem;
    }

    .premium-scroll h2 {
      max-width: 11ch;
      font-size: 3.2rem;
    }

    .premium-scroll__product {
      justify-self: start;
      width: min(100%, 28rem);
    }

    .premium-story__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .premium-scroll__pin {
      min-height: 108svh;
    }

    .premium-scroll__content {
      width: min(100% - 1.25rem, 72rem);
      padding: 5.5rem 0 3.5rem;
    }

    .premium-scroll h2 {
      font-size: 2.45rem;
      line-height: 1;
    }

    .premium-scroll__lead {
      font-size: 0.98rem;
      line-height: 1.75;
    }

    .premium-scroll__product {
      width: min(100%, 22rem);
    }

    .premium-scroll__product figcaption {
      color: rgba(255, 248, 232, 0.76);
    }

    .premium-story {
      width: min(100% - 1.25rem, 72rem);
      padding: 5rem 0 6rem;
    }

    .premium-story__intro h3 {
      font-size: 2.2rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .premium-scroll__coast,
    .premium-scroll__light,
    .premium-scroll__product,
    .premium-story__block {
      transform: none !important;
      filter: none !important;
    }
  }
</style>
